{
	"version": "1.0.0",
	"canvas": ".principal-views/decision-management/decision-management.otel.canvas",
	"mode": "span-tree",
	"name": "Decision List",
	"description": "Listing all decisions/ADRs",
	"scenarios": [
		{
			"id": "success",
			"priority": 1,
			"template": {
				"summary": "Listed {{decisionCount}} decisions ({{success}})",
				"events": {
					"decision.list.started": "List {{operation}} started",
					"decision.list.loaded": "Loaded {{decisionCount}} decisions",
					"decision.list.complete": "Listed {{decisionCount}} decisions ({{success}})"
				}
			},
			"description": "Decisions listed successfully"
		},
		{
			"id": "error",
			"priority": 2,
			"template": {
				"summary": "Decision list failed: {{error.message}}",
				"events": {
					"decision.list.started": "List {{operation}} started",
					"decision.list.loaded": "Loaded {{decisionCount}} decisions",
					"decision.error": "Error in {{operation}}: {{error.type}} - {{error.message}} at {{error.stage}}"
				}
			},
			"description": "Decision list failed with error"
		}
	],
	"spanPattern": "decision.list"
}
