{
	"version": "1.0.0",
	"canvas": ".principal-views/decision-management/decision-management.otel.canvas",
	"mode": "span-tree",
	"name": "Decision List",
	"description": "Listing all decisions/ADRs",
	"scenarios": [
		{
			"id": "success",
			"priority": 1,
			"template": {
				"summary": "Decisions listed",
				"events": {
					"decision.list.started": "List operation started",
					"decision.list.loaded": "Decisions loaded",
					"decision.list.complete": "Operation complete"
				}
			},
			"description": "Decisions listed successfully"
		},
		{
			"id": "error",
			"priority": 2,
			"template": {
				"summary": "Decision list failed",
				"events": {
					"decision.list.started": "List operation started",
					"decision.error": "Error occurred"
				}
			},
			"description": "Decision list failed with error"
		}
	],
	"spanPattern": "decision.list"
}
