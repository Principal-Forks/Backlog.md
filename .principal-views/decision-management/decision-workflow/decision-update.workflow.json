{
	"version": "1.0.0",
	"canvas": ".principal-views/decision-management/decision-management.otel.canvas",
	"mode": "span-tree",
	"name": "Decision Update",
	"description": "Updating an existing decision/ADR from markdown content",
	"scenarios": [
		{
			"id": "success",
			"priority": 1,
			"template": {
				"summary": "Decision updated",
				"events": {
					"decision.update.started": "Update operation started",
					"decision.update.loaded": "Decision loaded",
					"decision.update.parsed": "Content parsed",
					"decision.update.saved": "Decision saved",
					"decision.update.committed": "Changes committed",
					"decision.update.complete": "Operation complete"
				}
			},
			"description": "Decision updated successfully"
		},
		{
			"id": "error",
			"priority": 2,
			"template": {
				"summary": "Decision update failed",
				"events": {
					"decision.update.started": "Update operation started",
					"decision.error": "Error occurred"
				}
			},
			"description": "Decision update failed with error"
		}
	],
	"spanPattern": "decision.update"
}
