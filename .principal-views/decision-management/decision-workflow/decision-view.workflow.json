{
	"version": "1.0.0",
	"canvas": ".principal-views/decision-management/decision-management.otel.canvas",
	"mode": "span-tree",
	"name": "Decision View",
	"description": "Viewing a single decision/ADR by ID",
	"scenarios": [
		{
			"id": "success",
			"priority": 1,
			"template": {
				"summary": "Decision viewed",
				"events": {
					"decision.view.started": "View operation started",
					"decision.view.loaded": "Decision loaded",
					"decision.view.complete": "Operation complete"
				}
			},
			"description": "Decision viewed successfully"
		},
		{
			"id": "error",
			"priority": 2,
			"template": {
				"summary": "Decision view failed",
				"events": {
					"decision.view.started": "View operation started",
					"decision.error": "Error occurred"
				}
			},
			"description": "Decision view failed with error"
		}
	],
	"spanPattern": "decision.view"
}
