{
	"version": "1.0.0",
	"canvas": ".principal-views/decision-management/decision-management.otel.canvas",
	"mode": "span-tree",
	"name": "Decision Create",
	"description": "Creating a new ADR (Architecture Decision Record)",
	"scenarios": [
		{
			"id": "success",
			"priority": 1,
			"template": {
				"summary": "Decision created",
				"events": {
					"decision.create.started": "Create operation started",
					"decision.create.validated": "Decision validated",
					"decision.create.saved": "Decision saved",
					"decision.create.committed": "Changes committed",
					"decision.create.complete": "Operation complete"
				}
			},
			"description": "Decision created successfully"
		},
		{
			"id": "error",
			"priority": 2,
			"template": {
				"summary": "Decision creation failed",
				"events": {
					"decision.create.started": "Create operation started",
					"decision.error": "Error occurred"
				}
			},
			"description": "Decision creation failed with error"
		}
	],
	"spanPattern": "decision.create"
}
