{
	"version": "1.0.0",
	"canvas": ".principal-views/milestone-management/milestone-management.otel.canvas",
	"mode": "span-tree",
	"name": "Milestone Create",
	"description": "Creating a new milestone",
	"scenarios": [
		{
			"id": "success",
			"priority": 1,
			"template": {
				"summary": "Milestone created",
				"events": {
					"milestone.create.started": "Creation started",
					"milestone.create.validated": "Validated",
					"milestone.create.saved": "Saved",
					"milestone.create.committed": "Committed",
					"milestone.create.complete": "Complete"
				}
			},
			"description": "Milestone created successfully"
		},
		{
			"id": "error",
			"priority": 2,
			"template": {
				"summary": "Milestone create failed",
				"events": {
					"milestone.create.started": "Creation started",
					"milestone.error": "Error occurred"
				}
			},
			"description": "Milestone create failed with error"
		}
	],
	"spanPattern": "milestone.create"
}
