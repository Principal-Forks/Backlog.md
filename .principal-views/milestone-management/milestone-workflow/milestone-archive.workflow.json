{
	"version": "1.0.0",
	"canvas": ".principal-views/milestone-management/milestone-management.otel.canvas",
	"mode": "span-tree",
	"name": "Milestone Archive",
	"description": "Archiving a milestone by moving it to the archive directory",
	"scenarios": [
		{
			"id": "success",
			"priority": 1,
			"template": {
				"summary": "Milestone {{milestoneId}} archived ({{success}}) in {{duration.ms}}ms",
				"events": {
					"milestone.archive.started": "Archiving milestone {{identifier}} (autoCommit: {{autoCommit}})",
					"milestone.archive.located": "Located {{milestoneId}} at {{milestonePath}}: {{milestoneTitle}}",
					"milestone.archive.moved": "Moved from {{fromPath}} to {{toPath}}",
					"milestone.archive.committed": "Committed {{milestoneId}}: {{commitMessage}}",
					"milestone.archive.complete": "Milestone {{milestoneId}} archived ({{success}}) in {{duration.ms}}ms"
				}
			},
			"description": "Milestone archived successfully"
		},
		{
			"id": "error",
			"priority": 2,
			"template": {
				"summary": "Milestone archive failed: {{error.message}}",
				"events": {
					"milestone.archive.started": "Archiving milestone {{identifier}} (autoCommit: {{autoCommit}})",
					"milestone.archive.located": "Located {{milestoneId}} at {{milestonePath}}: {{milestoneTitle}}",
					"milestone.error": "Error in {{operation}}: {{error.type}} - {{error.message}} at {{error.stage}} for {{identifier}} ({{error.stack}})"
				}
			},
			"description": "Milestone archive failed with error"
		}
	],
	"spanPattern": "milestone.archive"
}
