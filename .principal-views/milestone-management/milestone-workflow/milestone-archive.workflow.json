{
	"version": "1.0.0",
	"canvas": ".principal-views/milestone-management/milestone-management.otel.canvas",
	"mode": "span-tree",
	"name": "Milestone Archive",
	"description": "Archiving a milestone by moving it to the archive directory",
	"scenarios": [
		{
			"id": "success",
			"priority": 1,
			"template": {
				"summary": "Milestone archived",
				"events": {
					"milestone.archive.started": "Archive operation started",
					"milestone.archive.located": "Milestone located",
					"milestone.archive.moved": "File moved",
					"milestone.archive.committed": "Changes committed",
					"milestone.archive.complete": "Operation complete"
				}
			},
			"description": "Milestone archived successfully"
		},
		{
			"id": "error",
			"priority": 2,
			"template": {
				"summary": "Milestone archive failed",
				"events": {
					"milestone.archive.started": "Archive operation started",
					"milestone.error": "Error occurred"
				}
			},
			"description": "Milestone archive failed with error"
		}
	],
	"spanPattern": "milestone.archive"
}
