{
	"version": "1.0.0",
	"canvas": ".principal-views/milestone-management/milestone-management.otel.canvas",
	"mode": "span-tree",
	"name": "Milestone View",
	"description": "Viewing milestone details",
	"scenarios": [
		{
			"id": "success",
			"priority": 1,
			"template": {
				"summary": "Milestone {{milestoneId}} viewed ({{success}}) in {{duration.ms}}ms",
				"events": {
					"milestone.view.started": "Viewing milestone {{milestoneId}} (format: {{format}})",
					"milestone.view.loaded": "Loaded {{milestoneId}}: {{title}}",
					"milestone.view.complete": "Milestone {{milestoneId}} viewed ({{success}}) in {{duration.ms}}ms"
				}
			},
			"description": "Milestone viewed successfully"
		},
		{
			"id": "error",
			"priority": 2,
			"template": {
				"summary": "Milestone view failed: {{error.message}}",
				"events": {
					"milestone.view.started": "Viewing milestone {{milestoneId}} (format: {{format}})",
					"milestone.view.loaded": "Loaded {{milestoneId}}: {{title}}",
					"milestone.error": "Error in {{operation}}: {{error.type}} - {{error.message}} at {{error.stage}} for {{identifier}} ({{error.stack}})"
				}
			},
			"description": "Milestone view failed with error"
		}
	],
	"spanPattern": "milestone.view"
}
