{
	"version": "1.0.0",
	"canvas": ".principal-views/milestone-management/milestone-management.otel.canvas",
	"mode": "span-tree",
	"name": "Milestone View",
	"description": "Viewing milestone details",
	"scenarios": [
		{
			"id": "success",
			"priority": 1,
			"template": {
				"summary": "Milestone viewed",
				"events": {
					"milestone.view.started": "View started",
					"milestone.view.loaded": "Milestone loaded",
					"milestone.view.complete": "View complete"
				}
			},
			"description": "Milestone viewed successfully"
		},
		{
			"id": "error",
			"priority": 2,
			"template": {
				"summary": "Milestone view failed",
				"events": {
					"milestone.view.started": "View started",
					"milestone.error": "Error occurred"
				}
			},
			"description": "Milestone view failed with error"
		}
	],
	"spanPattern": "milestone.view"
}
