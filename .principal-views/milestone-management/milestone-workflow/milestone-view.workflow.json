{
	"version": "1.0.0",
	"canvas": ".principal-views/milestone-management/milestone-management.otel.canvas",
	"mode": "span-tree",
	"name": "Milestone View",
	"description": "Viewing milestone details",
	"scenarios": [
		{
			"id": "success",
			"priority": 1,
			"template": {
				"summary": "Milestone {{milestoneId}} viewed ({{success}}) in {{duration.ms}}ms",
				"events": {
					"milestone.create.started": "Creating milestone: {{title}} (desc: {{description}}, autoCommit: {{autoCommit}})",
					"milestone.create.validated": "Validated {{milestoneId}} (nextId: {{nextId}})",
					"milestone.create.saved": "Saved {{milestoneId}} to {{filepath}} as {{filename}}",
					"milestone.create.committed": "Committed {{milestoneId}}: {{commitMessage}}",
					"milestone.create.complete": "Milestone {{milestoneId}} created ({{success}}) in {{duration.ms}}ms",
					"milestone.view.started": "Viewing milestone {{milestoneId}} (format: {{format}})",
					"milestone.view.loaded": "Loaded {{milestoneId}}: {{title}}",
					"milestone.view.complete": "Milestone {{milestoneId}} viewed ({{success}}) in {{duration.ms}}ms",
					"milestone.list.started": "List started (includeArchived: {{includeArchived}}, format: {{format}})",
					"milestone.list.loaded": "Loaded {{totalCount}} milestones ({{archivedCount}} archived)",
					"milestone.list.complete": "Listed {{resultCount}} milestones ({{success}}) in {{duration.ms}}ms",
					"milestone.archive.started": "Archiving milestone {{identifier}} (autoCommit: {{autoCommit}})",
					"milestone.archive.located": "Located {{milestoneId}} at {{milestonePath}}: {{milestoneTitle}}",
					"milestone.archive.moved": "Moved from {{fromPath}} to {{toPath}}",
					"milestone.archive.committed": "Committed {{milestoneId}}: {{commitMessage}}",
					"milestone.archive.complete": "Milestone {{milestoneId}} archived ({{success}}) in {{duration.ms}}ms",
					"milestone.error": "Error in {{operation}}: {{error.type}} - {{error.message}} at {{error.stage}} for {{identifier}} ({{error.stack}})"
				}
			},
			"description": "Milestone viewed successfully"
		},
		{
			"id": "error",
			"priority": 2,
			"template": {
				"summary": "Milestone view failed: {{error.message}}",
				"events": {
					"milestone.create.started": "Creating milestone: {{title}} (desc: {{description}}, autoCommit: {{autoCommit}})",
					"milestone.create.validated": "Validated {{milestoneId}} (nextId: {{nextId}})",
					"milestone.create.saved": "Saved {{milestoneId}} to {{filepath}} as {{filename}}",
					"milestone.create.committed": "Committed {{milestoneId}}: {{commitMessage}}",
					"milestone.create.complete": "Milestone {{milestoneId}} created ({{success}}) in {{duration.ms}}ms",
					"milestone.view.started": "Viewing milestone {{milestoneId}} (format: {{format}})",
					"milestone.view.loaded": "Loaded {{milestoneId}}: {{title}}",
					"milestone.view.complete": "Milestone {{milestoneId}} viewed ({{success}}) in {{duration.ms}}ms",
					"milestone.list.started": "List started (includeArchived: {{includeArchived}}, format: {{format}})",
					"milestone.list.loaded": "Loaded {{totalCount}} milestones ({{archivedCount}} archived)",
					"milestone.list.complete": "Listed {{resultCount}} milestones ({{success}}) in {{duration.ms}}ms",
					"milestone.archive.started": "Archiving milestone {{identifier}} (autoCommit: {{autoCommit}})",
					"milestone.archive.located": "Located {{milestoneId}} at {{milestonePath}}: {{milestoneTitle}}",
					"milestone.archive.moved": "Moved from {{fromPath}} to {{toPath}}",
					"milestone.archive.committed": "Committed {{milestoneId}}: {{commitMessage}}",
					"milestone.archive.complete": "Milestone {{milestoneId}} archived ({{success}}) in {{duration.ms}}ms",
					"milestone.error": "Error in {{operation}}: {{error.type}} - {{error.message}} at {{error.stage}} for {{identifier}} ({{error.stack}})"
				}
			},
			"description": "Milestone view failed with error"
		}
	],
	"spanPattern": "milestone.view"
}
