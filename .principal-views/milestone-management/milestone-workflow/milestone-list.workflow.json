{
	"version": "1.0.0",
	"canvas": ".principal-views/milestone-management/milestone-management.otel.canvas",
	"mode": "span-tree",
	"name": "Milestone List",
	"description": "Listing milestones",
	"scenarios": [
		{
			"id": "success",
			"priority": 1,
			"template": {
				"summary": "Listed {{resultCount}} milestones ({{success}}) in {{duration.ms}}ms",
				"events": {
					"milestone.list.started": "List started (includeArchived: {{includeArchived}}, format: {{format}})",
					"milestone.list.loaded": "Loaded {{totalCount}} milestones ({{archivedCount}} archived)",
					"milestone.list.complete": "Listed {{resultCount}} milestones ({{success}}) in {{duration.ms}}ms"
				}
			},
			"description": "Milestones listed successfully"
		},
		{
			"id": "error",
			"priority": 2,
			"template": {
				"summary": "Milestone list failed: {{error.message}}",
				"events": {
					"milestone.list.started": "List started (includeArchived: {{includeArchived}}, format: {{format}})",
					"milestone.list.loaded": "Loaded {{totalCount}} milestones ({{archivedCount}} archived)",
					"milestone.error": "Error in {{operation}}: {{error.type}} - {{error.message}} at {{error.stage}} for {{identifier}} ({{error.stack}})"
				}
			},
			"description": "Milestone list failed with error"
		}
	],
	"spanPattern": "milestone.list"
}
