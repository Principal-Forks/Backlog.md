{
	"version": "1.0.0",
	"canvas": ".principal-views/milestone-management/milestone-management.otel.canvas",
	"mode": "span-tree",
	"name": "Milestone List",
	"description": "Listing milestones",
	"scenarios": [
		{
			"id": "success",
			"priority": 1,
			"template": {
				"summary": "Milestones listed",
				"events": {
					"milestone.list.started": "List started",
					"milestone.list.loaded": "Milestones loaded",
					"milestone.list.complete": "List complete"
				}
			},
			"description": "Milestones listed successfully"
		},
		{
			"id": "error",
			"priority": 2,
			"template": {
				"summary": "Milestone list failed",
				"events": {
					"milestone.list.started": "List started",
					"milestone.error": "Error occurred"
				}
			},
			"description": "Milestone list failed with error"
		}
	],
	"spanPattern": "milestone.list"
}
