{
	"version": "1.0.0",
	"canvas": ".principal-views/init/init.otel.canvas",
	"mode": "span-tree",
	"name": "Backlog Init",
	"description": "CLI command for initializing a new Backlog.md workspace",
	"scenarios": [
		{
			"id": "success",
			"priority": 1,
			"template": {
				"summary": "Backlog initialized",
				"events": {
					"init.started": "Initialization started",
					"init.structure.created": "Structure created",
					"init.config.saved": "Configuration saved",
					"init.mcp.configured": "MCP configured",
					"init.complete": "Initialization complete"
				}
			},
			"description": "Backlog initialized successfully"
		},
		{
			"id": "error",
			"priority": 2,
			"template": {
				"summary": "Backlog init failed",
				"events": {
					"init.started": "Initialization started",
					"init.error": "Error occurred"
				}
			},
			"description": "Backlog init failed with error"
		}
	],
	"spanPattern": "init"
}
