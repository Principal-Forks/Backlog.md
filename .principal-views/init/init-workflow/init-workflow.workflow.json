{
	"version": "1.0.0",
	"canvas": ".principal-views/init/init.otel.canvas",
	"mode": "span-tree",
	"name": "Backlog Init",
	"description": "CLI command for initializing a new Backlog.md workspace",
	"scenarios": [
		{
			"id": "success",
			"priority": 1,
			"template": {
				"summary": "Backlog {{projectName}} initialized ({{success}}) in {{duration.ms}}ms",
				"events": {
					"init.started": "Init {{projectName}} (mode: {{integrationMode}}, reinit: {{isReInitialization}}, clients: {{mcpClients}}, advanced: {{hasAdvancedConfig}})",
					"init.structure.created": "Created {{created.directories}} directories and {{created.files}} files",
					"init.config.saved": "Saved config: {{config.projectName}} prefix={{config.taskPrefix}} autoCommit={{config.autoCommit}} zeroPadded={{config.zeroPaddedIds}} editor={{config.defaultEditor}}",
					"init.mcp.configured": "MCP configured: {{mcp.clients}} (success: {{mcp.successCount}}, failed: {{mcp.failureCount}}, errors: {{mcp.hasErrors}})",
					"init.complete": "Init complete ({{success}}, reinit: {{isReInitialization}}, mcp: {{hasMcpResults}}) in {{duration.ms}}ms"
				}
			},
			"description": "Backlog initialized successfully"
		},
		{
			"id": "error",
			"priority": 2,
			"template": {
				"summary": "Backlog init failed: {{error.message}}",
				"events": {
					"init.started": "Init {{projectName}} (mode: {{integrationMode}}, reinit: {{isReInitialization}}, clients: {{mcpClients}}, advanced: {{hasAdvancedConfig}})",
					"init.structure.created": "Created {{created.directories}} directories and {{created.files}} files",
					"init.config.saved": "Saved config: {{config.projectName}} prefix={{config.taskPrefix}} autoCommit={{config.autoCommit}} zeroPadded={{config.zeroPaddedIds}} editor={{config.defaultEditor}}",
					"init.error": "Error at {{error.stage}}: {{error.type}} - {{error.message}} ({{error.stack}})"
				}
			},
			"description": "Backlog init failed with error"
		}
	],
	"spanPattern": "init"
}
