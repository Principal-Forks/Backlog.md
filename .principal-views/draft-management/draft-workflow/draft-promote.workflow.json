{
	"version": "1.0.0",
	"canvas": ".principal-views/draft-management/draft-management.otel.canvas",
	"mode": "span-tree",
	"name": "Draft Promote",
	"description": "Promoting a draft to a task",
	"scenarios": [
		{
			"id": "success-with-commit",
			"priority": 1,
			"template": {
				"summary": "Draft promoted with auto-commit",
				"events": {
					"draft.promote.started": "Promoting draft {{draftId}} (autoCommit: {{autoCommit}})",
					"draft.promote.loaded": "Located draft at {{fromPath}}",
					"draft.promote.moved": "Moved {{fromPath}} to {{toPath}}",
					"draft.promote.committed": "Committed: {{commitMessage}}",
					"draft.promote.complete": "Completed in {{duration.ms}}ms (success: {{success}})"
				}
			},
			"description": "Draft successfully promoted to task with git commit"
		},
		{
			"id": "success-no-commit",
			"priority": 2,
			"template": {
				"summary": "Draft promoted without commit",
				"events": {
					"draft.promote.started": "Promoting draft {{draftId}} (autoCommit: {{autoCommit}})",
					"draft.promote.loaded": "Located draft at {{fromPath}}",
					"draft.promote.moved": "Moved {{fromPath}} to {{toPath}}",
					"draft.promote.commit-skipped": "Commit skipped",
					"draft.promote.complete": "Completed in {{duration.ms}}ms (success: {{success}})"
				}
			},
			"description": "Draft successfully promoted to task without git commit"
		},
		{
			"id": "error",
			"priority": 3,
			"template": {
				"summary": "Draft promotion failed",
				"events": {
					"draft.promote.started": "Attempting to promote draft {{draftId}}",
					"draft.error": "Error: {{error.message}} (type: {{error.type}})"
				}
			},
			"description": "Draft promotion failed with error"
		}
	],
	"spanPattern": "draft.promote"
}
