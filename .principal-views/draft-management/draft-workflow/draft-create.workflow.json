{
	"version": "1.0.0",
	"canvas": ".principal-views/draft-management/draft-management.otel.canvas",
	"name": "Draft Create",
	"description": "Creating a new draft in the backlog",
	"scenarios": [
		{
			"id": "success-with-commit",
			"priority": 1,
			"template": {
				"summary": "Draft {{draftId}} created ({{success}}) in {{duration.ms}}ms",
				"events": {
					"draft.create.started": "Creating draft: {{title}} (autoCommit: {{autoCommit}})",
					"draft.create.validated": "Validated {{draftId}} (normalized: {{normalizedId}})",
					"draft.create.saved": "Saved {{draftId}} to {{filepath}}",
					"draft.create.committed": "Committed {{draftId}}: {{commitMessage}}",
					"draft.create.complete": "Draft {{draftId}} created ({{success}}) in {{duration.ms}}ms"
				}
			},
			"description": "Draft successfully created with git commit"
		},
		{
			"id": "success-no-commit",
			"priority": 2,
			"template": {
				"summary": "Draft {{draftId}} created ({{success}}) in {{duration.ms}}ms",
				"events": {
					"draft.create.started": "Creating draft: {{title}} (autoCommit: {{autoCommit}})",
					"draft.create.validated": "Validated {{draftId}} (normalized: {{normalizedId}})",
					"draft.create.saved": "Saved {{draftId}} to {{filepath}}",
					"draft.create.commit-skipped": "Commit skipped for {{draftId}}",
					"draft.create.complete": "Draft {{draftId}} created ({{success}}) in {{duration.ms}}ms"
				}
			},
			"description": "Draft successfully created without git commit"
		},
		{
			"id": "error",
			"priority": 3,
			"template": {
				"summary": "Draft creation failed: {{error.message}}",
				"events": {
					"draft.create.started": "Creating draft: {{title}} (autoCommit: {{autoCommit}})",
					"draft.create.validated": "Validated {{draftId}} (normalized: {{normalizedId}})",
					"draft.error": "Error in {{operation}}: {{error.type}} - {{error.message}} at {{error.stage}} for {{draftId}} ({{error.stack}})"
				}
			},
			"description": "Draft creation failed with error"
		}
	],
	"spanPattern": "draft.create"
}
