{
	"version": "1.0.0",
	"canvas": ".principal-views/draft-management/draft-management.otel.canvas",
	"mode": "span-tree",
	"name": "Draft Create",
	"description": "Creating a new draft in the backlog",
	"scenarios": [
		{
			"id": "success-with-commit",
			"priority": 1,
			"template": {
				"summary": "Draft {{draftId}} created ({{success}}) in {{duration.ms}}ms",
				"events": {
					"draft.create.started": "Creating draft: {{title}} (autoCommit: {{autoCommit}})",
					"draft.create.validated": "Validated {{draftId}} (normalized: {{normalizedId}})",
					"draft.create.saved": "Saved {{draftId}} to {{filepath}}",
					"draft.create.committed": "Committed {{draftId}}: {{commitMessage}}",
					"draft.create.commit-skipped": "Commit skipped for {{draftId}}",
					"draft.create.complete": "Draft {{draftId}} created ({{success}}) in {{duration.ms}}ms",
					"filesystem.draft.view.started": "Loading draft {{draftId}}",
					"filesystem.draft.view.complete": "Loaded {{draftId}} from {{filepath}}: {{title}} in {{duration.ms}}ms",
					"filesystem.draft.view.not-found": "Draft {{draftId}} not found",
					"filesystem.draft.list.started": "List operation started",
					"filesystem.draft.list.scanned": "Found {{filesFound}} files",
					"filesystem.draft.list.complete": "Returned {{count}} drafts in {{duration.ms}}ms",
					"filesystem.draft.error": "Error in {{operation}}: {{error.type}} - {{error.message}} for {{draftId}}",
					"draft.promote.started": "Promoting draft {{draftId}} (autoCommit: {{autoCommit}})",
					"draft.promote.loaded": "Located {{draftId}} at {{fromPath}}",
					"draft.promote.moved": "Moved from {{fromPath}} to {{toPath}}",
					"draft.promote.committed": "Committed {{draftId}}: {{commitMessage}}",
					"draft.promote.commit-skipped": "Commit skipped for {{draftId}}",
					"draft.promote.complete": "Draft {{draftId}} promoted ({{success}}) in {{duration.ms}}ms",
					"draft.archive.started": "Archiving draft {{draftId}} (autoCommit: {{autoCommit}})",
					"draft.archive.located": "Located {{draftId}} at {{draftPath}} ({{draftFilename}})",
					"draft.archive.moved": "Moved from {{fromPath}} to {{toPath}}",
					"draft.archive.committed": "Committed {{normalizedDraftId}}: {{commitMessage}}",
					"draft.archive.commit-skipped": "Commit skipped for {{draftId}}",
					"draft.archive.complete": "Draft {{draftId}} archived ({{success}}) in {{duration.ms}}ms",
					"draft.error": "Error in {{operation}}: {{error.type}} - {{error.message}} at {{error.stage}} for {{draftId}} ({{error.stack}})"
				}
			},
			"description": "Draft successfully created with git commit"
		},
		{
			"id": "success-no-commit",
			"priority": 2,
			"template": {
				"summary": "Draft {{draftId}} created ({{success}}) in {{duration.ms}}ms",
				"events": {
					"draft.create.started": "Creating draft: {{title}} (autoCommit: {{autoCommit}})",
					"draft.create.validated": "Validated {{draftId}} (normalized: {{normalizedId}})",
					"draft.create.saved": "Saved {{draftId}} to {{filepath}}",
					"draft.create.committed": "Committed {{draftId}}: {{commitMessage}}",
					"draft.create.commit-skipped": "Commit skipped for {{draftId}}",
					"draft.create.complete": "Draft {{draftId}} created ({{success}}) in {{duration.ms}}ms",
					"filesystem.draft.view.started": "Loading draft {{draftId}}",
					"filesystem.draft.view.complete": "Loaded {{draftId}} from {{filepath}}: {{title}} in {{duration.ms}}ms",
					"filesystem.draft.view.not-found": "Draft {{draftId}} not found",
					"filesystem.draft.list.started": "List operation started",
					"filesystem.draft.list.scanned": "Found {{filesFound}} files",
					"filesystem.draft.list.complete": "Returned {{count}} drafts in {{duration.ms}}ms",
					"filesystem.draft.error": "Error in {{operation}}: {{error.type}} - {{error.message}} for {{draftId}}",
					"draft.promote.started": "Promoting draft {{draftId}} (autoCommit: {{autoCommit}})",
					"draft.promote.loaded": "Located {{draftId}} at {{fromPath}}",
					"draft.promote.moved": "Moved from {{fromPath}} to {{toPath}}",
					"draft.promote.committed": "Committed {{draftId}}: {{commitMessage}}",
					"draft.promote.commit-skipped": "Commit skipped for {{draftId}}",
					"draft.promote.complete": "Draft {{draftId}} promoted ({{success}}) in {{duration.ms}}ms",
					"draft.archive.started": "Archiving draft {{draftId}} (autoCommit: {{autoCommit}})",
					"draft.archive.located": "Located {{draftId}} at {{draftPath}} ({{draftFilename}})",
					"draft.archive.moved": "Moved from {{fromPath}} to {{toPath}}",
					"draft.archive.committed": "Committed {{normalizedDraftId}}: {{commitMessage}}",
					"draft.archive.commit-skipped": "Commit skipped for {{draftId}}",
					"draft.archive.complete": "Draft {{draftId}} archived ({{success}}) in {{duration.ms}}ms",
					"draft.error": "Error in {{operation}}: {{error.type}} - {{error.message}} at {{error.stage}} for {{draftId}} ({{error.stack}})"
				}
			},
			"description": "Draft successfully created without git commit"
		},
		{
			"id": "error",
			"priority": 3,
			"template": {
				"summary": "Draft creation failed: {{error.message}}",
				"events": {
					"draft.create.started": "Creating draft: {{title}} (autoCommit: {{autoCommit}})",
					"draft.create.validated": "Validated {{draftId}} (normalized: {{normalizedId}})",
					"draft.create.saved": "Saved {{draftId}} to {{filepath}}",
					"draft.create.committed": "Committed {{draftId}}: {{commitMessage}}",
					"draft.create.commit-skipped": "Commit skipped for {{draftId}}",
					"draft.create.complete": "Draft {{draftId}} created ({{success}}) in {{duration.ms}}ms",
					"filesystem.draft.view.started": "Loading draft {{draftId}}",
					"filesystem.draft.view.complete": "Loaded {{draftId}} from {{filepath}}: {{title}} in {{duration.ms}}ms",
					"filesystem.draft.view.not-found": "Draft {{draftId}} not found",
					"filesystem.draft.list.started": "List operation started",
					"filesystem.draft.list.scanned": "Found {{filesFound}} files",
					"filesystem.draft.list.complete": "Returned {{count}} drafts in {{duration.ms}}ms",
					"filesystem.draft.error": "Error in {{operation}}: {{error.type}} - {{error.message}} for {{draftId}}",
					"draft.promote.started": "Promoting draft {{draftId}} (autoCommit: {{autoCommit}})",
					"draft.promote.loaded": "Located {{draftId}} at {{fromPath}}",
					"draft.promote.moved": "Moved from {{fromPath}} to {{toPath}}",
					"draft.promote.committed": "Committed {{draftId}}: {{commitMessage}}",
					"draft.promote.commit-skipped": "Commit skipped for {{draftId}}",
					"draft.promote.complete": "Draft {{draftId}} promoted ({{success}}) in {{duration.ms}}ms",
					"draft.archive.started": "Archiving draft {{draftId}} (autoCommit: {{autoCommit}})",
					"draft.archive.located": "Located {{draftId}} at {{draftPath}} ({{draftFilename}})",
					"draft.archive.moved": "Moved from {{fromPath}} to {{toPath}}",
					"draft.archive.committed": "Committed {{normalizedDraftId}}: {{commitMessage}}",
					"draft.archive.commit-skipped": "Commit skipped for {{draftId}}",
					"draft.archive.complete": "Draft {{draftId}} archived ({{success}}) in {{duration.ms}}ms",
					"draft.error": "Error in {{operation}}: {{error.type}} - {{error.message}} at {{error.stage}} for {{draftId}} ({{error.stack}})"
				}
			},
			"description": "Draft creation failed with error"
		}
	],
	"spanPattern": "draft.create"
}
