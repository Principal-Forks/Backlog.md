{
	"version": "1.0.0",
	"canvas": ".principal-views/draft-management/draft-management.otel.canvas",
	"mode": "span-tree",
	"name": "Filesystem Draft View",
	"description": "Viewing a draft - filesystem-level operation (bypasses Core)",
	"scenarios": [
		{
			"id": "success",
			"priority": 1,
			"template": {
				"summary": "Draft {{draftId}} viewed: {{title}} in {{duration.ms}}ms",
				"events": {
					"filesystem.draft.view.started": "Loading draft {{draftId}}",
					"filesystem.draft.view.complete": "Loaded {{draftId}} from {{filepath}}: {{title}} in {{duration.ms}}ms"
				}
			},
			"description": "Draft successfully loaded from filesystem"
		},
		{
			"id": "not-found",
			"priority": 2,
			"template": {
				"summary": "Draft {{draftId}} not found",
				"events": {
					"filesystem.draft.view.started": "Loading draft {{draftId}}",
					"filesystem.draft.view.not-found": "Draft {{draftId}} not found"
				}
			},
			"description": "Draft not found in filesystem"
		},
		{
			"id": "error",
			"priority": 3,
			"template": {
				"summary": "Draft view failed: {{error.message}}",
				"events": {
					"filesystem.draft.view.started": "Loading draft {{draftId}}",
					"filesystem.draft.error": "Error in {{operation}}: {{error.type}} - {{error.message}} for {{draftId}}"
				}
			},
			"description": "Draft view operation failed"
		}
	],
	"spanPattern": "filesystem.draft.view"
}
