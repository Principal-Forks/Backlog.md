{
	"version": "1.0.0",
	"canvas": ".principal-views/draft-management/draft-management.otel.canvas",
	"mode": "span-tree",
	"name": "Draft Archive",
	"description": "Archiving a draft by moving it to the archive directory",
	"scenarios": [
		{
			"id": "success-with-commit",
			"priority": 1,
			"template": {
				"summary": "Draft {{draftId}} archived ({{success}}) in {{duration.ms}}ms",
				"events": {
					"draft.archive.started": "Archiving draft {{draftId}} (autoCommit: {{autoCommit}})",
					"draft.archive.located": "Located {{draftId}} at {{draftPath}} ({{draftFilename}})",
					"draft.archive.moved": "Moved from {{fromPath}} to {{toPath}}",
					"draft.archive.committed": "Committed {{normalizedDraftId}}: {{commitMessage}}",
					"draft.archive.complete": "Draft {{draftId}} archived ({{success}}) in {{duration.ms}}ms"
				}
			},
			"description": "Draft successfully archived with git commit"
		},
		{
			"id": "success-no-commit",
			"priority": 2,
			"template": {
				"summary": "Draft {{draftId}} archived ({{success}}) in {{duration.ms}}ms",
				"events": {
					"draft.archive.started": "Archiving draft {{draftId}} (autoCommit: {{autoCommit}})",
					"draft.archive.located": "Located {{draftId}} at {{draftPath}} ({{draftFilename}})",
					"draft.archive.moved": "Moved from {{fromPath}} to {{toPath}}",
					"draft.archive.commit-skipped": "Commit skipped for {{draftId}}",
					"draft.archive.complete": "Draft {{draftId}} archived ({{success}}) in {{duration.ms}}ms"
				}
			},
			"description": "Draft successfully archived without git commit"
		},
		{
			"id": "error",
			"priority": 3,
			"template": {
				"summary": "Draft archive failed: {{error.message}}",
				"events": {
					"draft.archive.started": "Archiving draft {{draftId}} (autoCommit: {{autoCommit}})",
					"draft.archive.located": "Located {{draftId}} at {{draftPath}} ({{draftFilename}})",
					"draft.error": "Error in {{operation}}: {{error.type}} - {{error.message}} at {{error.stage}} for {{draftId}} ({{error.stack}})"
				}
			},
			"description": "Draft archive failed with error"
		}
	],
	"spanPattern": "draft.archive"
}
