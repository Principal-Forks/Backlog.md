{
	"version": "1.0.0",
	"canvas": ".principal-views/draft-management/draft-management.otel.canvas",
	"mode": "span-tree",
	"name": "Draft Archive",
	"description": "Archiving a draft by moving it to the archive directory",
	"scenarios": [
		{
			"id": "success-with-commit",
			"priority": 1,
			"template": {
				"summary": "Draft archived with auto-commit",
				"events": {
					"draft.archive.started": "Archiving draft {{draftId}} (autoCommit: {{autoCommit}})",
					"draft.archive.located": "Located draft: {{title}}",
					"draft.archive.moved": "Moved to archive",
					"draft.archive.committed": "Committed: {{commitMessage}}",
					"draft.archive.complete": "Completed in {{duration.ms}}ms (success: {{success}})"
				}
			},
			"description": "Draft successfully archived with git commit"
		},
		{
			"id": "success-no-commit",
			"priority": 2,
			"template": {
				"summary": "Draft archived without commit",
				"events": {
					"draft.archive.started": "Archiving draft {{draftId}} (autoCommit: {{autoCommit}})",
					"draft.archive.located": "Located draft: {{title}}",
					"draft.archive.moved": "Moved to archive",
					"draft.archive.commit-skipped": "Commit skipped",
					"draft.archive.complete": "Completed in {{duration.ms}}ms (success: {{success}})"
				}
			},
			"description": "Draft successfully archived without git commit"
		},
		{
			"id": "error",
			"priority": 3,
			"template": {
				"summary": "Draft archive failed",
				"events": {
					"draft.archive.started": "Attempting to archive draft {{draftId}}",
					"draft.error": "Error: {{error.message}} (type: {{error.type}})"
				}
			},
			"description": "Draft archive failed with error"
		}
	],
	"spanPattern": "draft.archive"
}
