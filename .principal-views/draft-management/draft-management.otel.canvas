{
	"nodes": [
		{
			"id": "draft-create-started",
			"type": "text",
			"x": 100,
			"y": 50,
			"width": 200,
			"height": 100,
			"text": "# Create Started\n\nDraft creation initiated with title.",
			"pv": {
				"event": {
					"name": "draft.create.started",
					"attributes": {
						"title": {
							"type": "string",
							"required": true
						},
						"autoCommit": {
							"type": "boolean",
							"required": false
						}
					}
				},
				"references": [
					"src/core/backlog.ts",
					"src/cli.ts"
				],
