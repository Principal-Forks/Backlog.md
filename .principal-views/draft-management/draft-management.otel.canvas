					"kind": "event",
					"category": "lifecycle",
					"files": [
						"src/core/backlog.ts"
					]
				},
				"shape": "rectangle",
				"fill": "#22c55e",
				"stroke": "#16a34a",
				"status": "implemented"
			},
			"color": "#22c55e"
		},
