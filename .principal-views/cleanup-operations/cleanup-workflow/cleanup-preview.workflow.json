{
	"version": "1.0.0",
	"canvas": ".principal-views/cleanup-operations/cleanup-operations.otel.canvas",
	"mode": "span-tree",
	"name": "Cleanup Preview",
	"description": "Preview which tasks would be affected by cleanup operation",
	"scenarios": [
		{
			"id": "success",
			"priority": 1,
			"template": {
				"summary": "Cleanup preview: {{taskCount}} tasks ready for cleanup ({{success}})",
				"events": {
					"cleanup.preview.started": "Preview started for tasks older than {{olderThanDays}} days",
					"cleanup.preview.filtered": "Filtered {{matchedTasks}}/{{totalTasks}} tasks before {{cutoffDate}}",
					"cleanup.preview.complete": "Preview complete: {{taskCount}} tasks ({{success}})"
				}
			},
			"description": "Cleanup preview completed successfully"
		},
		{
			"id": "error",
			"priority": 2,
			"template": {
				"summary": "Cleanup preview failed: {{error.message}}",
				"events": {
					"cleanup.preview.started": "Preview started for tasks older than {{olderThanDays}} days",
					"cleanup.preview.filtered": "Filtered {{matchedTasks}}/{{totalTasks}} tasks before {{cutoffDate}}",
					"cleanup.error": "Error in {{operation}}: {{error.type}} - {{error.message}} at {{error.stage}} for task {{taskId}}"
				}
			},
			"description": "Cleanup preview failed with error"
		}
	],
	"spanPattern": "cleanup.preview"
}
