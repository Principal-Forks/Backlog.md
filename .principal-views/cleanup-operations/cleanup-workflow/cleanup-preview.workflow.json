{
	"version": "1.0.0",
	"canvas": ".principal-views/cleanup-operations/cleanup-operations.otel.canvas",
	"mode": "span-tree",
	"name": "Cleanup Preview",
	"description": "Preview which tasks would be affected by cleanup operation",
	"scenarios": [
		{
			"id": "success",
			"priority": 1,
			"template": {
				"summary": "Cleanup preview completed",
				"events": {
					"cleanup.preview.started": "Preview started",
					"cleanup.preview.filtered": "Tasks filtered",
					"cleanup.preview.complete": "Preview complete"
				}
			},
			"description": "Cleanup preview completed successfully"
		},
		{
			"id": "error",
			"priority": 2,
			"template": {
				"summary": "Cleanup preview failed",
				"events": {
					"cleanup.preview.started": "Preview started",
					"cleanup.error": "Error occurred"
				}
			},
			"description": "Cleanup preview failed with error"
		}
	],
	"spanPattern": "cleanup.preview"
}
