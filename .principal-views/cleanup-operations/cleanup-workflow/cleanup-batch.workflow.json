{
	"version": "1.0.0",
	"canvas": ".principal-views/cleanup-operations/cleanup-operations.otel.canvas",
	"mode": "span-tree",
	"name": "Cleanup Batch",
	"description": "Batch cleanup operation moving multiple Done tasks to completed folder",
	"scenarios": [
		{
			"id": "success",
			"priority": 1,
			"template": {
				"summary": "Cleanup batch completed: {{movedCount}}/{{totalCount}} tasks moved in {{duration.ms}}ms",
				"events": {
					"cleanup.batch.started": "Batch started: {{taskCount}} tasks older than {{olderThanDays}} days",
					"cleanup.batch.processing": "Processing task {{currentIndex}}/{{totalCount}}: {{taskId}}",
					"cleanup.batch.complete": "Batch complete: {{movedCount}}/{{totalCount}} moved, {{failedCount}} failed ({{success}}) in {{duration.ms}}ms"
				}
			},
			"description": "Batch cleanup completed successfully"
		},
		{
			"id": "error",
			"priority": 2,
			"template": {
				"summary": "Cleanup batch failed: {{error.message}}",
				"events": {
					"cleanup.batch.started": "Batch started: {{taskCount}} tasks older than {{olderThanDays}} days",
					"cleanup.batch.processing": "Processing task {{currentIndex}}/{{totalCount}}: {{taskId}}",
					"cleanup.error": "Error in {{operation}}: {{error.type}} - {{error.message}} at {{error.stage}} for task {{taskId}}"
				}
			},
			"description": "Batch cleanup failed with error"
		}
	],
	"spanPattern": "cleanup.batch"
}
