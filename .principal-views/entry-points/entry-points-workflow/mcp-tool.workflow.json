{
	"version": "1.0.0",
	"canvas": ".principal-views/entry-points/entry-points.otel.canvas",
	"mode": "span-tree",
	"name": "MCP Tool Call",
	"description": "Model Context Protocol tool invocation lifecycle",
	"scenarios": [
		{
			"id": "success",
			"priority": 1,
			"template": {
				"summary": "MCP tool completed",
				"events": {
					"mcp.tool.invoked": "Tool invoked",
					"mcp.tool.validated": "Parameters validated",
					"mcp.operation.dispatched": "Operation dispatched",
					"operation.executed": "Operation executed",
					"mcp.tool.response": "Response sent"
				}
			},
			"description": "MCP tool completed successfully"
		},
		{
			"id": "error",
			"priority": 2,
			"template": {
				"summary": "MCP tool failed",
				"events": {
					"mcp.tool.invoked": "Tool invoked",
					"entry.error": "Error occurred"
				}
			},
			"description": "MCP tool failed with error"
		}
	],
	"spanPattern": "mcp.tool"
}
