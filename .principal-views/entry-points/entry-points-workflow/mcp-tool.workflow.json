{
	"version": "1.0.0",
	"canvas": ".principal-views/entry-points/entry-points.otel.canvas",
	"mode": "span-tree",
	"name": "MCP Tool Call",
	"description": "Model Context Protocol tool invocation lifecycle",
	"scenarios": [
		{
			"id": "success",
			"priority": 1,
			"template": {
				"summary": "MCP {{toolName}} completed ({{success}}) in {{duration.ms}}ms",
				"events": {
					"mcp.tool.invoked": "Invoked {{toolName}} with params: {{parameters}} (client: {{clientId}})",
					"mcp.tool.validated": "Validated {{toolName}} for {{operation}} (valid: {{validationPassed}})",
					"mcp.operation.dispatched": "Dispatched {{operation}} to {{handler}}",
					"operation.executed": "Executed {{operation}} on {{entityType}} {{entityId}} ({{success}}) in {{duration.ms}}ms",
					"mcp.tool.response": "Response sent ({{success}}) {{contentLength}} bytes in {{duration.ms}}ms"
				}
			},
			"description": "MCP tool completed successfully"
		},
		{
			"id": "error",
			"priority": 2,
			"template": {
				"summary": "MCP tool failed: {{error.message}}",
				"events": {
					"mcp.tool.invoked": "Invoked {{toolName}} with params: {{parameters}} (client: {{clientId}})",
					"mcp.tool.validated": "Validated {{toolName}} for {{operation}} (valid: {{validationPassed}})",
					"entry.error": "Error in {{entryPoint}} {{operation}}: {{error.type}} - {{error.message}} at {{error.stage}} ({{error.stack}})"
				}
			},
			"description": "MCP tool failed with error"
		}
	],
	"spanPattern": "mcp.tool"
}
