{
	"version": "1.0.0",
	"canvas": ".principal-views/cleanup-operations/cleanup-operations.otel.canvas",
	"mode": "span-tree",
	"name": "Completed Tasks List",
	"description": "Listing all completed tasks from the completed folder",
	"scenarios": [
		{
			"id": "success",
			"priority": 1,
			"template": {
				"summary": "Completed tasks listed",
				"events": {
					"completed.tasks.list.started": "List started",
					"completed.tasks.list.loaded": "Tasks loaded",
					"completed.tasks.list.complete": "List complete"
				}
			},
			"description": "Completed tasks listed successfully"
		},
		{
			"id": "error",
			"priority": 2,
			"template": {
				"summary": "Completed tasks list failed",
				"events": {
					"completed.tasks.list.started": "List started",
					"cleanup.error": "Error occurred"
				}
			},
			"description": "Completed tasks list failed with error"
		}
	],
	"spanPattern": "completed.tasks"
}
