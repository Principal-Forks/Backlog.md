{
	"version": "1.0.0",
	"canvas": ".principal-views/entry-points/entry-points.otel.canvas",
	"mode": "span-tree",
	"name": "CLI Request",
	"description": "Command-line interface request lifecycle",
	"scenarios": [
		{
			"id": "success",
			"priority": 1,
			"template": {
				"summary": "CLI request completed",
				"events": {
					"cli.request.received": "Request received",
					"cli.request.parsed": "Request parsed",
					"cli.operation.dispatched": "Operation dispatched",
					"operation.executed": "Operation executed",
					"cli.request.complete": "Request complete"
				}
			},
			"description": "CLI request completed successfully"
		},
		{
			"id": "error",
			"priority": 2,
			"template": {
				"summary": "CLI request failed",
				"events": {
					"cli.request.received": "Request received",
					"entry.error": "Error occurred"
				}
			},
			"description": "CLI request failed with error"
		}
	],
	"spanPattern": "cli.request"
}
