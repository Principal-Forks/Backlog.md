{
	"version": "1.0.0",
	"canvas": ".principal-views/entry-points/entry-points.otel.canvas",
	"name": "CLI Request",
	"description": "Command-line interface request lifecycle",
	"scenarios": [
		{
			"id": "success",
			"priority": 1,
			"template": {
				"summary": "CLI {{command}} completed ({{success}}) in {{duration.ms}}ms",
				"events": {
					"cli.request.received": "Received {{command}} {{subcommand}} with args: {{args}} (cwd: {{cwd}})",
					"cli.request.parsed": "Parsed {{operation}} for {{entityType}} (valid: {{validationPassed}})",
					"cli.operation.dispatched": "Dispatched {{operation}} to {{handler}}",
					"operation.executed": "Executed {{operation}} on {{entityType}} {{entityId}} ({{success}}) in {{duration.ms}}ms",
					"cli.request.complete": "Complete ({{success}}) exit: {{exitCode}} in {{duration.ms}}ms"
				}
			},
			"description": "CLI request completed successfully"
		},
		{
			"id": "error",
			"priority": 2,
			"template": {
				"summary": "CLI request failed: {{error.message}}",
				"events": {
					"cli.request.received": "Received {{command}} {{subcommand}} with args: {{args}} (cwd: {{cwd}})",
					"cli.request.parsed": "Parsed {{operation}} for {{entityType}} (valid: {{validationPassed}})",
					"entry.error": "Error in {{entryPoint}} {{operation}}: {{error.type}} - {{error.message}} at {{error.stage}} ({{error.stack}})"
				}
			},
			"description": "CLI request failed with error"
		}
	],
	"spanPattern": "cli.request"
}
