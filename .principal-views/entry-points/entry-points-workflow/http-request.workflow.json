{
	"version": "1.0.0",
	"canvas": ".principal-views/entry-points/entry-points.otel.canvas",
	"mode": "span-tree",
	"name": "HTTP Request",
	"description": "HTTP API request lifecycle for browser interface",
	"scenarios": [
		{
			"id": "success",
			"priority": 1,
			"template": {
				"summary": "HTTP request completed",
				"events": {
					"http.request.received": "Request received",
					"http.request.routed": "Request routed",
					"http.operation.dispatched": "Operation dispatched",
					"operation.executed": "Operation executed",
					"http.response.sent": "Response sent"
				}
			},
			"description": "HTTP request completed successfully"
		},
		{
			"id": "error",
			"priority": 2,
			"template": {
				"summary": "HTTP request failed",
				"events": {
					"http.request.received": "Request received",
					"entry.error": "Error occurred"
				}
			},
			"description": "HTTP request failed with error"
		}
	],
	"spanPattern": "http.request"
}
