{
	"version": "1.0.0",
	"canvas": ".principal-views/entry-points/entry-points.otel.canvas",
	"mode": "span-tree",
	"name": "HTTP Request",
	"description": "HTTP API request lifecycle for browser interface",
	"scenarios": [
		{
			"id": "success",
			"priority": 1,
			"template": {
				"summary": "HTTP {{method}} {{path}} completed ({{statusCode}}) in {{duration.ms}}ms",
				"events": {
					"http.request.received": "Received {{method}} {{path}} from {{clientIp}} ({{userAgent}})",
					"http.request.routed": "Routed {{route}} to {{handler}} for {{operation}}",
					"http.operation.dispatched": "Dispatched {{operation}} to {{handler}} with body: {{requestBody}}",
					"operation.executed": "Executed {{operation}} on {{entityType}} {{entityId}} ({{success}}) in {{duration.ms}}ms",
					"http.response.sent": "Sent response ({{success}}) {{statusCode}} ({{responseSize}} bytes) in {{duration.ms}}ms"
				}
			},
			"description": "HTTP request completed successfully"
		},
		{
			"id": "error",
			"priority": 2,
			"template": {
				"summary": "HTTP request failed: {{error.message}}",
				"events": {
					"http.request.received": "Received {{method}} {{path}} from {{clientIp}} ({{userAgent}})",
					"http.request.routed": "Routed {{route}} to {{handler}} for {{operation}}",
					"entry.error": "Error in {{entryPoint}} {{operation}}: {{error.type}} - {{error.message}} at {{error.stage}} ({{error.stack}})"
				}
			},
			"description": "HTTP request failed with error"
		}
	],
	"spanPattern": "http.request"
}
