{
	"version": "1.0.0",
	"canvas": ".principal-views/document-management/document-management.otel.canvas",
	"mode": "span-tree",
	"name": "Document View",
	"description": "Viewing a single document by ID",
	"scenarios": [
		{
			"id": "success",
			"priority": 1,
			"template": {
				"summary": "Document viewed",
				"events": {
					"document.view.started": "View operation started",
					"document.view.loaded": "Document loaded",
					"document.view.complete": "Operation complete"
				}
			},
			"description": "Document viewed successfully"
		},
		{
			"id": "error",
			"priority": 2,
			"template": {
				"summary": "Document view failed",
				"events": {
					"document.view.started": "View operation started",
					"document.error": "Error occurred"
				}
			},
			"description": "Document view failed with error"
		}
	],
	"spanPattern": "document.view"
}
