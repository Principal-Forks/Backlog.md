{
	"version": "1.0.0",
	"canvas": ".principal-views/document-management/document-management.otel.canvas",
	"name": "Document View",
	"description": "Viewing a single document by ID",
	"scenarios": [
		{
			"id": "success",
			"priority": 1,
			"template": {
				"summary": "Document {{documentId}} viewed ({{success}})",
				"events": {
					"document.view.started": "Viewing document {{documentId}}",
					"document.view.loaded": "Loaded {{documentId}} from {{documentPath}}",
					"document.view.complete": "Document {{documentId}} viewed ({{success}})"
				}
			},
			"description": "Document viewed successfully"
		},
		{
			"id": "error",
			"priority": 2,
			"template": {
				"summary": "Document view failed: {{error.message}}",
				"events": {
					"document.view.started": "Viewing document {{documentId}}",
					"document.view.loaded": "Loaded {{documentId}} from {{documentPath}}",
					"document.error": "Error in {{operation}}: {{error.type}} - {{error.message}} at {{error.stage}}"
				}
			},
			"description": "Document view failed with error"
		}
	],
	"spanPattern": "document.view"
}
