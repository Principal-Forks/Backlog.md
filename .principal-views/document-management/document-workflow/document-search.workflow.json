{
	"version": "1.0.0",
	"canvas": ".principal-views/document-management/document-management.otel.canvas",
	"mode": "span-tree",
	"name": "Document Search",
	"description": "Full-text search across document content",
	"scenarios": [
		{
			"id": "success",
			"priority": 1,
			"template": {
				"summary": "Document search completed",
				"events": {
					"document.search.started": "Search operation started",
					"document.search.executed": "Search executed",
					"document.search.complete": "Operation complete"
				}
			},
			"description": "Document search completed successfully"
		},
		{
			"id": "error",
			"priority": 2,
			"template": {
				"summary": "Document search failed",
				"events": {
					"document.search.started": "Search operation started",
					"document.error": "Error occurred"
				}
			},
			"description": "Document search failed with error"
		}
	],
	"spanPattern": "document.search"
}
