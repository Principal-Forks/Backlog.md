{
	"version": "1.0.0",
	"canvas": ".principal-views/document-management/document-management.otel.canvas",
	"mode": "span-tree",
	"name": "Document Create",
	"description": "Creating a new document",
	"scenarios": [
		{
			"id": "success",
			"priority": 1,
			"template": {
				"summary": "Document created",
				"events": {
					"document.create.started": "Create operation started",
					"document.create.validated": "Document validated",
					"document.create.saved": "Document saved",
					"document.create.committed": "Changes committed",
					"document.create.complete": "Operation complete"
				}
			},
			"description": "Document created successfully"
		},
		{
			"id": "error",
			"priority": 2,
			"template": {
				"summary": "Document creation failed",
				"events": {
					"document.create.started": "Create operation started",
					"document.error": "Error occurred"
				}
			},
			"description": "Document creation failed with error"
		}
	],
	"spanPattern": "document.create"
}
