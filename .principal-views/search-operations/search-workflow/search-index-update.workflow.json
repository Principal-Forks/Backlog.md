{
	"version": "1.0.0",
	"canvas": ".principal-views/search-operations/search-operations.otel.canvas",
	"mode": "span-tree",
	"name": "Search Index Update",
	"description": "Updating the search index when content changes",
	"scenarios": [
		{
			"id": "success",
			"priority": 1,
			"template": {
				"summary": "Search index updated",
				"events": {
					"search.index.update.started": "Update started",
					"search.index.snapshot.applied": "Snapshot applied",
					"search.index.rebuilt": "Index rebuilt",
					"search.index.update.complete": "Update complete"
				}
			},
			"description": "Search index updated successfully"
		},
		{
			"id": "error",
			"priority": 2,
			"template": {
				"summary": "Search index update failed",
				"events": {
					"search.index.update.started": "Update started",
					"search.error": "Error occurred"
				}
			},
			"description": "Search index update failed with error"
		}
	],
	"spanPattern": "search.index.update"
}
