{
	"version": "1.0.0",
	"canvas": ".principal-views/search-operations/search-operations.otel.canvas",
	"name": "Search Index Update",
	"description": "Updating the search index when content changes",
	"scenarios": [
		{
			"id": "success",
			"priority": 1,
			"template": {
				"summary": "Search index v{{version}} updated ({{success}})",
				"events": {
					"search.index.update.started": "Update started: {{trigger}} (version: {{version}})",
					"search.index.snapshot.applied": "Snapshot applied: {{taskCount}} tasks, {{documentCount}} docs, {{decisionCount}} decisions",
					"search.index.rebuilt": "Index rebuilt: {{totalEntities}} entities in {{rebuildDuration.ms}}ms",
					"search.index.update.complete": "Update complete v{{version}} ({{success}})"
				}
			},
			"description": "Search index updated successfully"
		},
		{
			"id": "error",
			"priority": 2,
			"template": {
				"summary": "Search index update failed: {{error.message}}",
				"events": {
					"search.index.update.started": "Update started: {{trigger}} (version: {{version}})",
					"search.index.snapshot.applied": "Snapshot applied: {{taskCount}} tasks, {{documentCount}} docs, {{decisionCount}} decisions",
					"search.error": "Error in {{operation}}: {{error.type}} - {{error.message}} at {{error.stage}}"
				}
			},
			"description": "Search index update failed with error"
		}
	],
	"spanPattern": "search.index.update"
}
