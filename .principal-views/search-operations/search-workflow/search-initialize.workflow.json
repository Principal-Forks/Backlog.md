{
	"version": "1.0.0",
	"canvas": ".principal-views/search-operations/search-operations.otel.canvas",
	"mode": "span-tree",
	"name": "Search Initialize",
	"description": "Initializing the search service and building the index",
	"scenarios": [
		{
			"id": "success",
			"priority": 1,
			"template": {
				"summary": "Search initialized",
				"events": {
					"search.initialize.started": "Initialization started",
					"search.initialize.snapshot": "Snapshot loaded",
					"search.initialize.indexed": "Index built",
					"search.initialize.complete": "Initialization complete"
				}
			},
			"description": "Search initialized successfully"
		},
		{
			"id": "error",
			"priority": 2,
			"template": {
				"summary": "Search initialization failed",
				"events": {
					"search.initialize.started": "Initialization started",
					"search.error": "Error occurred"
				}
			},
			"description": "Search initialization failed with error"
		}
	],
	"spanPattern": "search.initialize"
}
