{
	"version": "1.0.0",
	"canvas": ".principal-views/search-operations/search-operations.otel.canvas",
	"mode": "span-tree",
	"name": "Search Initialize",
	"description": "Initializing the search service and building the index",
	"scenarios": [
		{
			"id": "success",
			"priority": 1,
			"template": {
				"summary": "Search initialized ({{success}}) in {{duration.ms}}ms",
				"events": {
					"search.initialize.started": "Initialization {{operation}} started",
					"search.initialize.snapshot": "Snapshot loaded: {{taskCount}} tasks, {{documentCount}} docs, {{decisionCount}} decisions",
					"search.initialize.indexed": "Index built: {{totalEntities}} entities ({{taskVariants}} task variants)",
					"search.initialize.complete": "Initialization complete ({{success}}) in {{duration.ms}}ms"
				}
			},
			"description": "Search initialized successfully"
		},
		{
			"id": "error",
			"priority": 2,
			"template": {
				"summary": "Search initialization failed: {{error.message}}",
				"events": {
					"search.initialize.started": "Initialization {{operation}} started",
					"search.initialize.snapshot": "Snapshot loaded: {{taskCount}} tasks, {{documentCount}} docs, {{decisionCount}} decisions",
					"search.error": "Error in {{operation}}: {{error.type}} - {{error.message}} at {{error.stage}}"
				}
			},
			"description": "Search initialization failed with error"
		}
	],
	"spanPattern": "search.initialize"
}
