{
	"version": "1.0.0",
	"canvas": ".principal-views/task-management/task-management.otel.canvas",
	"mode": "span-tree",
	"name": "Task List",
	"description": "Listing and filtering tasks",
	"scenarios": [
		{
			"id": "success",
			"priority": 1,
			"template": {
				"summary": "Tasks listed",
				"events": {
					"task.list.started": "List started",
					"task.list.loaded": "Tasks loaded",
					"task.list.filtered": "Filters applied",
					"task.list.complete": "List complete"
				}
			},
			"description": "Tasks listed successfully"
		},
		{
			"id": "error",
			"priority": 2,
			"template": {
				"summary": "Task list failed",
				"events": {
					"task.list.started": "List started",
					"task.error": "Error occurred"
				}
			},
			"description": "Task list failed with error"
		}
	],
	"spanPattern": "task.list"
}
