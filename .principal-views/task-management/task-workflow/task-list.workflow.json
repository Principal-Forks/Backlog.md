{
	"version": "1.0.0",
	"canvas": ".principal-views/task-management/task-management.otel.canvas",
	"mode": "span-tree",
	"name": "Task List",
	"description": "Listing tasks with filters",
	"scenarios": [
		{
			"id": "success",
			"priority": 1,
			"template": {
				"summary": "Listed {{resultCount}} tasks ({{success}}) in {{duration.ms}}ms",
				"events": {
					"task.list.started": "List started (filters: {{filters}}, format: {{format}})",
					"task.list.loaded": "Loaded {{totalCount}} tasks (crossBranch: {{includeCrossBranch}})",
					"task.list.filtered": "Filtered to {{resultCount}} (filters: {{appliedFilters}})",
					"task.list.complete": "Listed {{resultCount}} tasks ({{success}}) in {{duration.ms}}ms"
				}
			},
			"description": "Tasks listed successfully"
		},
		{
			"id": "error",
			"priority": 2,
			"template": {
				"summary": "Task list failed: {{error.message}}",
				"events": {
					"task.list.started": "List started (filters: {{filters}}, format: {{format}})",
					"task.list.loaded": "Loaded {{totalCount}} tasks (crossBranch: {{includeCrossBranch}})",
					"task.error": "Error in {{operation}}: {{error.type}} - {{error.message}} at {{error.stage}} for {{taskId}} ({{error.stack}})"
				}
			},
			"description": "Task list failed with error"
		}
	],
	"spanPattern": "task.list"
}
