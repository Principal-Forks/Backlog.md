{
	"version": "1.0.0",
	"canvas": ".principal-views/task-management/task-management.otel.canvas",
	"mode": "span-tree",
	"name": "Task Edit",
	"description": "Editing an existing task",
	"scenarios": [
		{
			"id": "success",
			"priority": 1,
			"template": {
				"summary": "Task edited",
				"events": {
					"task.edit.started": "Edit started",
					"task.edit.loaded": "Task loaded",
					"task.edit.validated": "Validated",
					"task.edit.updated": "Updated",
					"task.edit.committed": "Committed",
					"task.edit.complete": "Complete"
				}
			},
			"description": "Task edited successfully"
		},
		{
			"id": "error",
			"priority": 2,
			"template": {
				"summary": "Task edit failed",
				"events": {
					"task.edit.started": "Edit started",
					"task.error": "Error occurred"
				}
			},
			"description": "Task edit failed with error"
		}
	],
	"spanPattern": "task.edit"
}
