{
	"version": "1.0.0",
	"canvas": ".principal-views/task-management/task-management.otel.canvas",
	"name": "Task Edit",
	"description": "Editing an existing task",
	"scenarios": [
		{
			"id": "success",
			"priority": 1,
			"template": {
				"summary": "Task {{taskId}} edited ({{success}}) in {{duration.ms}}ms",
				"events": {
					"task.edit.started": "Editing task {{taskId}} (fields: {{updateFields}}, autoCommit: {{autoCommit}})",
					"task.edit.loaded": "Loaded {{taskId}} (status: {{currentStatus}})",
					"task.edit.validated": "Validated {{taskId}} (hasChanges: {{hasChanges}})",
					"task.edit.updated": "Updated {{taskId}} fields: {{updatedFields}}",
					"task.edit.committed": "Committed {{taskId}}: {{commitMessage}}",
					"task.edit.complete": "Task {{taskId}} edited ({{success}}) in {{duration.ms}}ms"
				}
			},
			"description": "Task edited successfully"
		},
		{
			"id": "error",
			"priority": 2,
			"template": {
				"summary": "Task edit failed: {{error.message}}",
				"events": {
					"task.edit.started": "Editing task {{taskId}} (fields: {{updateFields}}, autoCommit: {{autoCommit}})",
					"task.edit.loaded": "Loaded {{taskId}} (status: {{currentStatus}})",
					"task.edit.validated": "Validated {{taskId}} (hasChanges: {{hasChanges}})",
					"task.error": "Error in {{operation}}: {{error.type}} - {{error.message}} at {{error.stage}} for {{taskId}} ({{error.stack}})"
				}
			},
			"description": "Task edit failed with error"
		}
	],
	"spanPattern": "task.edit"
}
