{
	"version": "1.0.0",
	"canvas": ".principal-views/task-management/task-management.otel.canvas",
	"mode": "span-tree",
	"name": "Task Complete",
	"description": "Moving a single task to the completed folder",
	"scenarios": [
		{
			"id": "success",
			"priority": 1,
			"template": {
				"summary": "Task {{taskId}} completed ({{success}})",
				"events": {
					"task.complete.started": "Completing task {{taskId}} (autoCommit: {{autoCommit}})",
					"task.complete.located": "Located {{taskId}} at {{sourcePath}} ({{filename}})",
					"task.complete.moved": "Moved {{taskId}} from {{fromPath}} to {{toPath}}",
					"task.complete.committed": "Committed {{taskId}}: {{commitMessage}}",
					"task.complete.complete": "Task {{taskId}} completed ({{success}})"
				}
			},
			"description": "Task completed successfully"
		},
		{
			"id": "error",
			"priority": 2,
			"template": {
				"summary": "Task complete failed: {{error.message}}",
				"events": {
					"task.complete.started": "Completing task {{taskId}} (autoCommit: {{autoCommit}})",
					"task.complete.located": "Located {{taskId}} at {{sourcePath}} ({{filename}})",
					"task.error": "Error in {{operation}}: {{error.type}} - {{error.message}} at {{error.stage}} for {{taskId}} ({{error.stack}})"
				}
			},
			"description": "Task complete failed with error"
		}
	],
	"spanPattern": "task.complete"
}
