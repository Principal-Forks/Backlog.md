{
	"version": "1.0.0",
	"canvas": ".principal-views/task-management/task-management.otel.canvas",
	"mode": "span-tree",
	"name": "Task Create",
	"description": "Creating a new task in the backlog",
	"scenarios": [
		{
			"id": "success",
			"priority": 1,
			"template": {
				"summary": "Task created",
				"events": {
					"task.create.started": "Creation started",
					"task.create.validated": "Validated",
					"task.create.saved": "Saved",
					"task.create.committed": "Committed",
					"task.create.complete": "Complete"
				}
			},
			"description": "Task created successfully"
		},
		{
			"id": "error",
			"priority": 2,
			"template": {
				"summary": "Task create failed",
				"events": {
					"task.create.started": "Creation started",
					"task.error": "Error occurred"
				}
			},
			"description": "Task create failed with error"
		}
	],
	"spanPattern": "task.create"
}
