{
	"version": "1.0.0",
	"canvas": ".principal-views/task-management/task-management.otel.canvas",
	"name": "Task Create",
	"description": "Creating a new task in the backlog",
	"scenarios": [
		{
			"id": "success",
			"priority": 1,
			"template": {
				"summary": "Task {{taskId}} created ({{success}}) in {{duration.ms}}ms",
				"events": {
					"task.create.started": "Creating task: {{title}} (status: {{status}}, autoCommit: {{autoCommit}})",
					"task.create.validated": "Validated {{taskId}} (normalized: {{normalizedId}})",
					"task.create.saved": "Saved {{taskId}} to {{filepath}}",
					"task.create.committed": "Committed {{taskId}}: {{commitMessage}}",
					"task.create.complete": "Task {{taskId}} created ({{success}}) in {{duration.ms}}ms"
				}
			},
			"description": "Task created successfully"
		},
		{
			"id": "error",
			"priority": 2,
			"template": {
				"summary": "Task create failed: {{error.message}}",
				"events": {
					"task.create.started": "Creating task: {{title}} (status: {{status}}, autoCommit: {{autoCommit}})",
					"task.create.validated": "Validated {{taskId}} (normalized: {{normalizedId}})",
					"task.error": "Error in {{operation}}: {{error.type}} - {{error.message}} at {{error.stage}} for {{taskId}} ({{error.stack}})"
				}
			},
			"description": "Task create failed with error"
		}
	],
	"spanPattern": "task.create"
}
