{
	"version": "1.0.0",
	"canvas": ".principal-views/task-management/task-management.otel.canvas",
	"mode": "span-tree",
	"name": "Task Archive",
	"description": "Archiving a task by moving it to the archive directory",
	"scenarios": [
		{
			"id": "success",
			"priority": 1,
			"template": {
				"summary": "Task archived",
				"events": {
					"task.archive.started": "Archive operation started",
					"task.archive.located": "Task located",
					"task.archive.moved": "File moved",
					"task.archive.committed": "Changes committed",
					"task.archive.complete": "Operation complete"
				}
			},
			"description": "Task archived successfully"
		},
		{
			"id": "error",
			"priority": 2,
			"template": {
				"summary": "Task archive failed",
				"events": {
					"task.archive.started": "Archive operation started",
					"task.error": "Error occurred"
				}
			},
			"description": "Task archive failed with error"
		}
	],
	"spanPattern": "task.archive"
}
