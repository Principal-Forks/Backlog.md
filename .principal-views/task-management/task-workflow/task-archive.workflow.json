{
	"version": "1.0.0",
	"canvas": ".principal-views/task-management/task-management.otel.canvas",
	"mode": "span-tree",
	"name": "Task Archive",
	"description": "Archiving a task by moving it to the archive directory",
	"scenarios": [
		{
			"id": "success",
			"priority": 1,
			"template": {
				"summary": "Task {{taskId}} archived ({{success}}) in {{duration.ms}}ms",
				"events": {
					"task.create.started": "Creating task: {{title}} (status: {{status}}, autoCommit: {{autoCommit}})",
					"task.create.validated": "Validated {{taskId}} (normalized: {{normalizedId}})",
					"task.create.saved": "Saved {{taskId}} to {{filepath}}",
					"task.create.committed": "Committed {{taskId}}: {{commitMessage}}",
					"task.create.complete": "Task {{taskId}} created ({{success}}) in {{duration.ms}}ms",
					"task.edit.started": "Editing task {{taskId}} (fields: {{updateFields}}, autoCommit: {{autoCommit}})",
					"task.edit.loaded": "Loaded {{taskId}} (status: {{currentStatus}})",
					"task.edit.validated": "Validated {{taskId}} (hasChanges: {{hasChanges}})",
					"task.edit.updated": "Updated {{taskId}} fields: {{updatedFields}}",
					"task.edit.committed": "Committed {{taskId}}: {{commitMessage}}",
					"task.edit.complete": "Task {{taskId}} edited ({{success}}) in {{duration.ms}}ms",
					"task.view.started": "Viewing task {{taskId}} (format: {{format}})",
					"task.view.loaded": "Loaded {{taskId}} (hasSubtasks: {{hasSubtasks}}, source: {{source}})",
					"task.view.complete": "Task {{taskId}} viewed ({{success}}) in {{duration.ms}}ms",
					"task.list.started": "List started (filters: {{filters}}, format: {{format}})",
					"task.list.loaded": "Loaded {{totalCount}} tasks (crossBranch: {{includeCrossBranch}})",
					"task.list.filtered": "Filtered to {{resultCount}} (filters: {{appliedFilters}})",
					"task.list.complete": "Listed {{resultCount}} tasks ({{success}}) in {{duration.ms}}ms",
					"task.demote.started": "Demoting task {{taskId}} (autoCommit: {{autoCommit}})",
					"task.demote.loaded": "Located {{taskId}} at {{fromPath}}",
					"task.demote.moved": "Moved from {{fromPath}} to {{toPath}}",
					"task.demote.committed": "Committed {{taskId}}: {{commitMessage}}",
					"task.demote.complete": "Task {{taskId}} demoted ({{success}}) in {{duration.ms}}ms",
					"task.archive.started": "Archiving task {{taskId}} (autoCommit: {{autoCommit}})",
					"task.archive.located": "Located {{taskId}} at {{taskPath}} ({{taskFilename}})",
					"task.archive.moved": "Moved from {{fromPath}} to {{toPath}}",
					"task.archive.committed": "Committed {{normalizedTaskId}}: {{commitMessage}}",
					"task.archive.complete": "Task {{taskId}} archived ({{success}}) in {{duration.ms}}ms",
					"task.complete.started": "Completing task {{taskId}} (autoCommit: {{autoCommit}})",
					"task.complete.located": "Located {{taskId}} at {{sourcePath}} ({{filename}})",
					"task.complete.moved": "Moved {{taskId}} from {{fromPath}} to {{toPath}}",
					"task.complete.committed": "Committed {{taskId}}: {{commitMessage}}",
					"task.complete.complete": "Task {{taskId}} completed ({{success}})",
					"task.error": "Error in {{operation}}: {{error.type}} - {{error.message}} at {{error.stage}} for {{taskId}} ({{error.stack}})"
				}
			},
			"description": "Task archived successfully"
		},
		{
			"id": "error",
			"priority": 2,
			"template": {
				"summary": "Task archive failed: {{error.message}}",
				"events": {
					"task.create.started": "Creating task: {{title}} (status: {{status}}, autoCommit: {{autoCommit}})",
					"task.create.validated": "Validated {{taskId}} (normalized: {{normalizedId}})",
					"task.create.saved": "Saved {{taskId}} to {{filepath}}",
					"task.create.committed": "Committed {{taskId}}: {{commitMessage}}",
					"task.create.complete": "Task {{taskId}} created ({{success}}) in {{duration.ms}}ms",
					"task.edit.started": "Editing task {{taskId}} (fields: {{updateFields}}, autoCommit: {{autoCommit}})",
					"task.edit.loaded": "Loaded {{taskId}} (status: {{currentStatus}})",
					"task.edit.validated": "Validated {{taskId}} (hasChanges: {{hasChanges}})",
					"task.edit.updated": "Updated {{taskId}} fields: {{updatedFields}}",
					"task.edit.committed": "Committed {{taskId}}: {{commitMessage}}",
					"task.edit.complete": "Task {{taskId}} edited ({{success}}) in {{duration.ms}}ms",
					"task.view.started": "Viewing task {{taskId}} (format: {{format}})",
					"task.view.loaded": "Loaded {{taskId}} (hasSubtasks: {{hasSubtasks}}, source: {{source}})",
					"task.view.complete": "Task {{taskId}} viewed ({{success}}) in {{duration.ms}}ms",
					"task.list.started": "List started (filters: {{filters}}, format: {{format}})",
					"task.list.loaded": "Loaded {{totalCount}} tasks (crossBranch: {{includeCrossBranch}})",
					"task.list.filtered": "Filtered to {{resultCount}} (filters: {{appliedFilters}})",
					"task.list.complete": "Listed {{resultCount}} tasks ({{success}}) in {{duration.ms}}ms",
					"task.demote.started": "Demoting task {{taskId}} (autoCommit: {{autoCommit}})",
					"task.demote.loaded": "Located {{taskId}} at {{fromPath}}",
					"task.demote.moved": "Moved from {{fromPath}} to {{toPath}}",
					"task.demote.committed": "Committed {{taskId}}: {{commitMessage}}",
					"task.demote.complete": "Task {{taskId}} demoted ({{success}}) in {{duration.ms}}ms",
					"task.archive.started": "Archiving task {{taskId}} (autoCommit: {{autoCommit}})",
					"task.archive.located": "Located {{taskId}} at {{taskPath}} ({{taskFilename}})",
					"task.archive.moved": "Moved from {{fromPath}} to {{toPath}}",
					"task.archive.committed": "Committed {{normalizedTaskId}}: {{commitMessage}}",
					"task.archive.complete": "Task {{taskId}} archived ({{success}}) in {{duration.ms}}ms",
					"task.complete.started": "Completing task {{taskId}} (autoCommit: {{autoCommit}})",
					"task.complete.located": "Located {{taskId}} at {{sourcePath}} ({{filename}})",
					"task.complete.moved": "Moved {{taskId}} from {{fromPath}} to {{toPath}}",
					"task.complete.committed": "Committed {{taskId}}: {{commitMessage}}",
					"task.complete.complete": "Task {{taskId}} completed ({{success}})",
					"task.error": "Error in {{operation}}: {{error.type}} - {{error.message}} at {{error.stage}} for {{taskId}} ({{error.stack}})"
				}
			},
			"description": "Task archive failed with error"
		}
	],
	"spanPattern": "task.archive"
}
