{
	"version": "1.0.0",
	"canvas": ".principal-views/task-management/task-management.otel.canvas",
	"mode": "span-tree",
	"name": "Task Archive",
	"description": "Archiving a task by moving it to the archive directory",
	"scenarios": [
		{
			"id": "success",
			"priority": 1,
			"template": {
				"summary": "Task {{taskId}} archived ({{success}}) in {{duration.ms}}ms",
				"events": {
					"task.archive.started": "Archiving task {{taskId}} (autoCommit: {{autoCommit}})",
					"task.archive.located": "Located {{taskId}} at {{taskPath}} ({{taskFilename}})",
					"task.archive.moved": "Moved from {{fromPath}} to {{toPath}}",
					"task.archive.committed": "Committed {{normalizedTaskId}}: {{commitMessage}}",
					"task.archive.complete": "Task {{taskId}} archived ({{success}}) in {{duration.ms}}ms"
				}
			},
			"description": "Task archived successfully"
		},
		{
			"id": "error",
			"priority": 2,
			"template": {
				"summary": "Task archive failed: {{error.message}}",
				"events": {
					"task.archive.started": "Archiving task {{taskId}} (autoCommit: {{autoCommit}})",
					"task.archive.located": "Located {{taskId}} at {{taskPath}} ({{taskFilename}})",
					"task.error": "Error in {{operation}}: {{error.type}} - {{error.message}} at {{error.stage}} for {{taskId}} ({{error.stack}})"
				}
			},
			"description": "Task archive failed with error"
		}
	],
	"spanPattern": "task.archive"
}
