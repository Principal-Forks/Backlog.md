{
	"version": "1.0.0",
	"canvas": ".principal-views/task-management/task-management.otel.canvas",
	"name": "Task Demote",
	"description": "Demoting a task back to draft status",
	"scenarios": [
		{
			"id": "success",
			"priority": 1,
			"template": {
				"summary": "Task {{taskId}} demoted ({{success}}) in {{duration.ms}}ms",
				"events": {
					"task.demote.started": "Demoting task {{taskId}} (autoCommit: {{autoCommit}})",
					"task.demote.loaded": "Located {{taskId}} at {{fromPath}}",
					"task.demote.moved": "Moved from {{fromPath}} to {{toPath}}",
					"task.demote.committed": "Committed {{taskId}}: {{commitMessage}}",
					"task.demote.complete": "Task {{taskId}} demoted ({{success}}) in {{duration.ms}}ms"
				}
			},
			"description": "Task demoted successfully"
		},
		{
			"id": "error",
			"priority": 2,
			"template": {
				"summary": "Task demotion failed: {{error.message}}",
				"events": {
					"task.demote.started": "Demoting task {{taskId}} (autoCommit: {{autoCommit}})",
					"task.demote.loaded": "Located {{taskId}} at {{fromPath}}",
					"task.error": "Error in {{operation}}: {{error.type}} - {{error.message}} at {{error.stage}} for {{taskId}} ({{error.stack}})"
				}
			},
			"description": "Task demotion failed with error"
		}
	],
	"spanPattern": "task.demote"
}
