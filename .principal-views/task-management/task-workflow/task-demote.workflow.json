{
	"version": "1.0.0",
	"canvas": ".principal-views/task-management/task-management.otel.canvas",
	"mode": "span-tree",
	"name": "Task Demote",
	"description": "Demoting a task back to draft status",
	"scenarios": [
		{
			"id": "success",
			"priority": 1,
			"template": {
				"summary": "Task demoted",
				"events": {
					"task.demote.started": "Demotion started",
					"task.demote.loaded": "Task located",
					"task.demote.moved": "File moved",
					"task.demote.committed": "Changes committed",
					"task.demote.complete": "Demotion complete"
				}
			},
			"description": "Task demoted successfully"
		},
		{
			"id": "error",
			"priority": 2,
			"template": {
				"summary": "Task demotion failed",
				"events": {
					"task.demote.started": "Demotion started",
					"task.error": "Error occurred"
				}
			},
			"description": "Task demotion failed with error"
		}
	],
	"spanPattern": "task.demote"
}
