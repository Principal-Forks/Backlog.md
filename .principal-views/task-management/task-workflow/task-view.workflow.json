{
	"version": "1.0.0",
	"canvas": ".principal-views/task-management/task-management.otel.canvas",
	"mode": "span-tree",
	"name": "Task View",
	"description": "Viewing task details",
	"scenarios": [
		{
			"id": "success",
			"priority": 1,
			"template": {
				"summary": "Task viewed",
				"events": {
					"task.view.started": "View started",
					"task.view.loaded": "Task loaded",
					"task.view.complete": "View complete"
				}
			},
			"description": "Task viewed successfully"
		},
		{
			"id": "error",
			"priority": 2,
			"template": {
				"summary": "Task view failed",
				"events": {
					"task.view.started": "View started",
					"task.error": "Error occurred"
				}
			},
			"description": "Task view failed with error"
		}
	],
	"spanPattern": "task.view"
}
