{
	"version": "1.0.0",
	"canvas": ".principal-views/task-management/task-management.otel.canvas",
	"name": "Task View",
	"description": "Viewing task details",
	"scenarios": [
		{
			"id": "success",
			"priority": 1,
			"template": {
				"summary": "Task {{taskId}} viewed ({{success}}) in {{duration.ms}}ms",
				"events": {
					"task.view.started": "Viewing task {{taskId}} (format: {{format}})",
					"task.view.loaded": "Loaded {{taskId}} (hasSubtasks: {{hasSubtasks}}, source: {{source}})",
					"task.view.complete": "Task {{taskId}} viewed ({{success}}) in {{duration.ms}}ms"
				}
			},
			"description": "Task viewed successfully"
		},
		{
			"id": "error",
			"priority": 2,
			"template": {
				"summary": "Task view failed: {{error.message}}",
				"events": {
					"task.view.started": "Viewing task {{taskId}} (format: {{format}})",
					"task.view.loaded": "Loaded {{taskId}} (hasSubtasks: {{hasSubtasks}}, source: {{source}})",
					"task.error": "Error in {{operation}}: {{error.type}} - {{error.message}} at {{error.stage}} for {{taskId}} ({{error.stack}})"
				}
			},
			"description": "Task view failed with error"
		}
	],
	"spanPattern": "task.view"
}
